  "metadata": {
    "id": "floating_verdant_isle",
    "name": "The Floating Verdance",
    "description": "A self-contained floating island suspended in an infinite void. A rectangular landmass descends from snow-capped northwestern peaks through temperate highlands and dense forests into sunlit central grasslands, a fragrant flowering grove, parched desert expanses, and a smoldering volcanic southern reach. Mountain meltwater weaves through every biome as rivers and streams before plunging off the island's cliff edges as spectacular waterfalls. A narrow coastal beach and shallow ocean ring the perimeter, where the land ultimately falls away into the endless void below.",
    "schema_version": "1.0.0",
    "seed": null,
    "tags": ["floating", "island", "volcanic", "alpine", "desert", "waterfall", "biome_gradient"]
  },
